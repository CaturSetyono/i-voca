---
import Layout from '../layouts/Layout.astro';
import CelebrationModal from '../components/CelebrationModal.astro';
---

<Layout title="VocabForge | Home">
	<main class="flex-1 flex flex-col p-6 gap-8 animate-zoom-in">
		<!-- Header -->
		<header class="flex justify-between items-center">
			<div class="flex flex-col">
				<span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400">Selamat Menempa,</span>
				<h1 class="text-3xl font-black uppercase tracking-tighter text-brand-secondary font-display">Forge Master</h1>
			</div>
			<div class="h-12 w-12 bg-white border-2 border-brand-outline rounded-2xl shadow-sm flex items-center justify-center text-brand-primary">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
			</div>
		</header>

		<!-- Top Section: Progress Bar -->
		<section class="clay-card !p-5 flex flex-col gap-4 bg-white/80 backdrop-blur-sm">
			<div class="flex justify-between items-end">
				<div class="flex flex-col">
					<span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Peringkat Saat Ini</span>
					<h2 class="text-xl font-black text-brand-primary uppercase leading-none font-display" id="level-display">LEVEL 1</h2>
				</div>
				<span class="font-black text-xs text-brand-secondary" id="xp-display">0 / 100 XP</span>
			</div>
			<div class="w-full h-6 bg-brand-bg border-2 border-brand-outline rounded-full overflow-hidden shadow-inner p-1">
				<div 
					id="progress-bar"
					class="h-full bg-brand-success rounded-full transition-all duration-700 ease-out relative shadow-[0_0_10px_rgba(52,211,153,0.4)]" 
					style="width: 0%"
				>
					<div class="absolute inset-0 bg-white/20 animate-pulse"></div>
				</div>
			</div>
		</section>

		<!-- Stats Section: Grid -->
		<section class="grid grid-cols-2 gap-4">
			<div class="clay-card flex flex-col items-center justify-center text-center py-6 group hover:-translate-y-1 transition-all">
				<div class="h-10 w-10 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mb-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5v-15A2.5 2.5 0 0 1 6.5 2Z"/></svg>
				</div>
				<span class="text-4xl font-black text-brand-primary font-display" id="total-words">0</span>
				<span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mt-1">Total Kata</span>
			</div>
			<div class="clay-card flex flex-col items-center justify-center text-center py-6 group hover:-translate-y-1 transition-all">
				<div class="h-10 w-10 rounded-xl bg-brand-accent/10 flex items-center justify-center text-brand-accent mb-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
				</div>
				<span class="text-4xl font-black text-brand-accent font-display" id="total-badges">0</span>
				<span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mt-1">Lencana</span>
			</div>
		</section>

		<!-- Action Section: Add Button -->
		<section>
			<a href="/add" class="clay-btn-success w-full text-xl py-5 shadow-[0_6px_0_0_#059669] flex items-center justify-center gap-3">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
				<span class="font-display uppercase italic">Tempa Kosakata</span>
			</a>
		</section>

		<!-- List Section: Recent Vocab -->
		<section class="flex-1 flex flex-col gap-6">
			<div class="flex flex-col gap-4 px-1">
				<h3 class="font-black text-lg uppercase tracking-tighter text-brand-secondary font-display">Riwayat Tempaan</h3>
				
				<!-- Search/Filter Feature -->
				<div class="relative w-full">
					<input 
						type="text" 
						id="search-vocab" 
						placeholder="Cari kata yang sudah ditempa..." 
						class="clay-input !py-3 !px-12 !text-sm w-full bg-white/50 focus:bg-white transition-all"
					/>
					<div class="absolute left-4 top-1/2 -translate-y-1/2 text-brand-primary/40">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
					</div>
				</div>
			</div>
			
			<div id="vocab-list" class="flex flex-col gap-4 pb-28">
				<!-- Content populated by JS -->
				<div class="clay-card !bg-transparent border-dashed !shadow-none py-12 flex flex-col items-center gap-4">
					<div class="h-16 w-16 text-gray-200 animate-pulse">
						<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v5l3 3"/><circle cx="12" cy="12" r="10"/></svg>
					</div>
					<p class="text-gray-400 font-bold italic text-center px-8 text-sm uppercase tracking-wider">
						Dapur tempaan masih dingin...
					</p>
				</div>
			</div>
		</section>
	</main>

	<!-- Bottom Navigation -->
	<nav class="fixed bottom-0 left-0 right-0 w-full bg-white/90 backdrop-blur-md border-t-2 border-brand-outline p-6 flex justify-around items-center z-40 max-w-[440px] mx-auto rounded-t-[32px] shadow-[0_-8px_20px_rgba(0,0,0,0.05)]">
		<a href="/" class="flex flex-col items-center gap-2 group">
			<div class="h-14 w-14 bg-brand-primary rounded-2xl shadow-[0_4px_0_0_#047857] flex items-center justify-center text-white transition-all active:translate-y-[2px] active:shadow-none">
				<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
			</div>
			<span class="text-[10px] font-black uppercase tracking-widest text-brand-primary">Home</span>
		</a>
		<a href="/badges" class="flex flex-col items-center gap-2 group">
			<div class="h-14 w-14 bg-white border-2 border-brand-outline rounded-2xl shadow-sm flex items-center justify-center text-gray-300 transition-all hover:text-brand-accent hover:border-brand-accent/20 active:translate-y-[2px] active:shadow-none">
				<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
			</div>
			<span class="text-[10px] font-black uppercase tracking-widest text-gray-300">Badges</span>
		</a>
	</nav>
</Layout>

<script lang="ts">
	import { getVocabData, getUserProfile, deleteVocabEntry } from '../utils/storage.js';

	let currentVocab: any[] = [];
	let searchQuery = '';

	function renderVocabList(vocabToRender: any[]) {
		const vocabList = document.getElementById('vocab-list');
		if (!vocabList) return;

		if (vocabToRender.length === 0) {
			const emptyMsg = searchQuery 
				? `Tidak ada hasil untuk "${searchQuery}"`
				: 'Belum ada kata yang ditempa... Mulailah sekarang!';
			
			vocabList.innerHTML = `
				<div class="clay-card !bg-transparent border-dashed !shadow-none py-12 flex flex-col items-center gap-4">
					<div class="h-16 w-16 text-gray-200">
						<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v5l3 3"/><circle cx="12" cy="12" r="10"/></svg>
					</div>
					<p class="text-gray-400 font-bold italic text-center px-8 text-sm">
						${emptyMsg}
					</p>
				</div>
			`;
		} else {
			vocabList.innerHTML = vocabToRender.map(word => `
				<div class="clay-card !p-5 flex justify-between items-center group relative overflow-hidden animate-slide-up" data-id="${word.id}">
					<div class="absolute left-0 top-0 bottom-0 w-1.5 bg-brand-primary/20"></div>
					<div class="pl-2">
						<p class="font-black text-xl uppercase tracking-tighter leading-tight text-brand-secondary font-display">${word.word_id}</p>
						<p class="text-brand-primary font-bold italic text-xs mt-0.5">${word.word_en}</p>
					</div>
					<button class="delete-btn h-10 w-10 flex items-center justify-center rounded-xl border-2 border-brand-outline bg-white hover:bg-red-50 hover:border-red-500 transition-all cursor-pointer shadow-sm active:translate-y-[1px] active:shadow-none" data-id="${word.id}">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
					</button>
				</div>
			`).join('');

			// Add delete listeners
			document.querySelectorAll('.delete-btn').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const id = (e.currentTarget as HTMLElement).dataset.id;
					if (id && confirm('Hapus kata ini dari koleksi tempaan Anda?')) {
						deleteVocabEntry(id);
						init(); // Re-render
					}
				});
			});
		}
	}

	function init() {
		const profile = getUserProfile();
		currentVocab = getVocabData();

		// Update Profile UI
		const levelDisplay = document.getElementById('level-display');
		const xpDisplay = document.getElementById('xp-display');
		const progressBar = document.getElementById('progress-bar');
		const totalWordsDisplay = document.getElementById('total-words');
		const totalBadgesDisplay = document.getElementById('total-badges');

		if (levelDisplay) {
			let title = 'IRON FORGER';
			if (profile.level >= 5) title = 'STEEL SMITH';
			if (profile.level >= 10) title = 'VOCAB TITAN';
			levelDisplay.textContent = `LVL ${profile.level} - ${title}`;
		}
		if (xpDisplay) xpDisplay.textContent = `${profile.current_xp} / 100 XP`;
		if (progressBar) progressBar.style.width = `${profile.current_xp}%`;
		if (totalWordsDisplay) totalWordsDisplay.textContent = currentVocab.length.toString();
		if (totalBadgesDisplay) totalBadgesDisplay.textContent = profile.unlocked_badges.length.toString();

		// Initial render
		filterAndRender();
	}

	function filterAndRender() {
		const filtered = currentVocab.filter(word => 
			word.word_id.toLowerCase().includes(searchQuery.toLowerCase()) || 
			word.word_en.toLowerCase().includes(searchQuery.toLowerCase())
		);
		renderVocabList(filtered);
	}

	// Search listener
	document.getElementById('search-vocab')?.addEventListener('input', (e) => {
		searchQuery = (e.target as HTMLInputElement).value;
		filterAndRender();
	});

	// Initialize UI
	init();
</script>
