---
import Layout from '../layouts/Layout.astro';

const badges = [
	{ 
		id: 'badge_01', 
		name: 'Novice Smith', 
		desc: 'Menandakan pengguna mulai menempa fondasi bahasanya.', 
		requirement: '10 Kata',
		icon: '/assets/badges/badge_01.svg'
	},
	{ 
		id: 'badge_02', 
		name: 'Word Weaver', 
		desc: 'Pengguna mulai bisa merajut kata-kata dasar.', 
		requirement: '25 Kata',
		icon: '/assets/badges/badge_02.svg'
	},
	{ 
		id: 'badge_03', 
		name: 'Fluent Voyager', 
		desc: 'Pengguna siap berlayar lebih jauh ke percakapan kasual.', 
		requirement: '50 Kata',
		icon: '/assets/badges/badge_03.svg'
	},
	{ 
		id: 'badge_04', 
		name: 'Vocab Titan', 
		desc: 'Pengguna memiliki kekuatan memori kosakata yang besar.', 
		requirement: '100 Kata',
		icon: '/assets/badges/badge_04.svg'
	}
];
---

<Layout title="VocabForge | Badge Room">
	<main class="flex-1 flex flex-col p-6 gap-8">
		<header class="flex items-center gap-4">
			<a href="/dashboard" class="h-12 w-12 flex items-center justify-center rounded-xl border-2 border-brand-text bg-white shadow-neo-sm active:translate-x-[1px] active:translate-y-[1px] active:shadow-none transition-all">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
			</a>
			<h1 class="text-2xl font-black uppercase">Badge Room</h1>
		</header>

		<div class="grid grid-cols-1 gap-6 pb-8" id="badges-container">
			{badges.map((badge) => (
				<div class="card-3d flex items-center gap-6 group transition-all" data-badge-id={badge.id}>
					<div class="relative">
						<div class="h-24 w-24 flex items-center justify-center rounded-2xl border-4 border-brand-text bg-brand-bg shadow-neo-sm badge-icon-container overflow-hidden">
							<img src={badge.icon} alt={badge.name} class="w-16 h-16 badge-img grayscale opacity-30 transition-all duration-500" />
							<div class="absolute inset-0 flex items-center justify-center lock-icon">
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand-text"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
							</div>
						</div>
					</div>
					<div class="flex-1">
						<h3 class="font-black text-xl leading-tight badge-name text-gray-400">{badge.name}</h3>
						<p class="text-xs font-bold text-brand-primary mb-1 uppercase tracking-tighter">{badge.requirement}</p>
						<p class="text-sm font-medium leading-snug badge-desc text-gray-400 italic">{badge.desc}</p>
					</div>
				</div>
			))}
		</div>
	</main>

	<!-- Bottom Navigation -->
	<nav class="sticky bottom-0 w-full bg-white border-t-4 border-brand-text p-4 flex justify-around">
		<a href="/dashboard" class="font-black text-gray-400 flex flex-col items-center gap-1">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
			<span class="text-[10px] uppercase">Home</span>
		</a>
		<a href="/badges" class="font-black text-brand-primary flex flex-col items-center gap-1">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
			<span class="text-[10px] uppercase">Badges</span>
		</a>
	</nav>
</Layout>

<script>
	import { getUserProfile } from '../utils/storage.js';

	function updateBadgesUI() {
		const profile = getUserProfile();
		const unlocked = profile.unlocked_badges || [];

		unlocked.forEach(badgeId => {
			const badgeEl = document.querySelector(`[data-badge-id="${badgeId}"]`);
			if (badgeEl) {
				const img = badgeEl.querySelector('.badge-img');
				const lock = badgeEl.querySelector('.lock-icon');
				const name = badgeEl.querySelector('.badge-name');
				const desc = badgeEl.querySelector('.badge-desc');

				img?.classList.remove('grayscale', 'opacity-30');
				lock?.classList.add('hidden');
				name?.classList.remove('text-gray-400');
				name?.classList.add('text-brand-text');
				desc?.classList.remove('text-gray-400', 'italic');
				desc?.classList.add('text-brand-text');
				
				// Optional: add a glow effect or specific background
				badgeEl.classList.add('bg-mint-50'); // We don't have mint-50 defined yet, but we could
			}
		});
	}

	updateBadgesUI();
</script>
