---
import Layout from '../layouts/Layout.astro';

const badges = [
	{ 
		id: 'badge_01', 
		name: 'Novice Smith', 
		desc: 'Menandakan Anda telah menempa fondasi bahasa Anda.', 
		requirement: '10 Kata',
		icon: '/assets/badges/badge_01.svg',
		color: 'bg-blue-100'
	},
	{ 
		id: 'badge_02', 
		name: 'Word Weaver', 
		desc: 'Anda mulai mahir merajut untaian kata-kata dasar.', 
		requirement: '25 Kata',
		icon: '/assets/badges/badge_02.svg',
		color: 'bg-emerald-100'
	},
	{ 
		id: 'badge_03', 
		name: 'Fluent Voyager', 
		desc: 'Siap berlayar lebih jauh ke samudera percakapan.', 
		requirement: '50 Kata',
		icon: '/assets/badges/badge_03.svg',
		color: 'bg-amber-100'
	},
	{ 
		id: 'badge_04', 
		name: 'Vocab Titan', 
		desc: 'Kekuatan memori kosakata Anda sungguh luar biasa.', 
		requirement: '100 Kata',
		icon: '/assets/badges/badge_04.svg',
		color: 'bg-purple-100'
	}
];
---

<Layout title="VocabForge | Badge Room">
	<main class="flex-1 flex flex-col p-6 gap-8 animate-zoom-in max-w-[500px] mx-auto w-full">
		<header class="flex items-center gap-6">
			<a href="/" class="h-12 w-12 flex items-center justify-center rounded-2xl border-2 border-brand-outline bg-white shadow-sm active:translate-y-[1px] active:shadow-none transition-all text-brand-primary">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
			</a>
			<div class="flex flex-col">
				<span class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400">Ruang Pencapaian</span>
				<h1 class="text-3xl font-black uppercase tracking-tighter text-brand-secondary font-display leading-none">Badge Room</h1>
			</div>
		</header>

		<section class="flex flex-col gap-4">
			<div class="clay-card !p-4 bg-brand-primary/5 border-brand-primary/10">
				<p class="font-bold text-brand-primary text-[11px] uppercase tracking-wider text-center">
					Tempa kosakata Anda setiap hari untuk membuka koleksi lencana legendaris!
				</p>
			</div>
		</section>

		<div class="grid grid-cols-1 gap-6 pb-24" id="badges-container">
			{badges.map((badge) => (
				<div class="clay-card flex items-center gap-5 group transition-all relative overflow-hidden opacity-40 grayscale" data-badge-id={badge.id}>
					<!-- Status Label -->
					<div class="absolute top-0 right-0 bg-brand-secondary text-white px-3 py-1 rounded-bl-xl text-[8px] font-black uppercase tracking-widest badge-status">
						Locked
					</div>

					<div class="relative shrink-0">
						<div class={`h-24 w-24 flex items-center justify-center rounded-2xl border-2 border-brand-outline ${badge.color}/30 badge-icon-container overflow-hidden relative shadow-inner`}>
							<img src={badge.icon} alt={badge.name} class="w-14 h-14 badge-img transition-all duration-700 opacity-20 scale-90" />
							
							<!-- Lock Overlay -->
							<div class="absolute inset-0 flex items-center justify-center lock-icon bg-white/40 backdrop-blur-[1px]">
								<div class="h-10 w-10 bg-white border-2 border-brand-outline rounded-xl shadow-sm flex items-center justify-center animate-float">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand-secondary"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
								</div>
							</div>
						</div>
					</div>

					<div class="flex-1 flex flex-col gap-1 pr-2">
						<div class="flex flex-col">
							<span class="text-[9px] font-black uppercase tracking-widest text-brand-primary mb-1 badge-req">{badge.requirement}</span>
							<h3 class="font-black text-xl uppercase tracking-tighter leading-none badge-name text-gray-400 font-display">{badge.name}</h3>
						</div>
						<p class="text-[11px] font-bold leading-snug badge-desc text-gray-300 italic line-clamp-2">{badge.desc}</p>
					</div>
				</div>
			))}
		</div>
	</main>

	<!-- Bottom Navigation -->
	<nav class="fixed bottom-0 left-0 right-0 w-full bg-white/90 backdrop-blur-md border-t-2 border-brand-outline p-6 flex justify-around items-center z-40 max-w-[500px] mx-auto rounded-t-3xl shadow-[0_-4px_10px_rgba(0,0,0,0.05)]">
		<a href="/" class="flex flex-col items-center gap-2 group">
			<div class="h-12 w-12 bg-white border-2 border-brand-outline rounded-2xl shadow-sm flex items-center justify-center text-gray-300 transition-all hover:text-brand-primary active:translate-y-[2px] active:shadow-none">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
			</div>
			<span class="text-[10px] font-black uppercase tracking-widest text-gray-300">Home</span>
		</a>
		<a href="/badges" class="flex flex-col items-center gap-2 group">
			<div class="h-12 w-12 bg-brand-accent rounded-2xl shadow-[0_4px_0_0_#CA8A04] flex items-center justify-center text-brand-text transition-all active:translate-y-[2px] active:shadow-none">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
			</div>
			<span class="text-[10px] font-black uppercase tracking-widest text-brand-accent">Badges</span>
		</a>
	</nav>
</Layout>

<script>
	import { getUserProfile } from '../utils/storage.js';

	function updateBadgesUI() {
		const profile = getUserProfile();
		const unlocked = profile.unlocked_badges || [];

		unlocked.forEach(badgeId => {
			const badgeEl = document.querySelector(`[data-badge-id="${badgeId}"]`);
			if (badgeEl) {
				const img = badgeEl.querySelector('.badge-img');
				const lock = badgeEl.querySelector('.lock-icon');
				const name = badgeEl.querySelector('.badge-name');
				const desc = badgeEl.querySelector('.badge-desc');
				const status = badgeEl.querySelector('.badge-status');

				badgeEl.classList.remove('grayscale', 'opacity-40');
				badgeEl.classList.add('bg-white', 'shadow-neo');
				
				if (img) {
					img.classList.remove('opacity-20', 'scale-90');
					img.classList.add('opacity-100', 'scale-100', 'animate-zoom-in');
				}
				
				lock?.classList.add('hidden');
				
				if (name) {
					name.classList.remove('text-gray-400');
					name.classList.add('text-brand-text');
				}
				
				if (desc) {
					desc.classList.remove('text-gray-300', 'italic');
					desc.classList.add('text-brand-text');
				}
				
				if (status) {
					status.textContent = 'Unlocked';
					status.classList.remove('bg-brand-secondary');
					status.classList.add('bg-brand-success');
				}
			}
		});
	}

	document.addEventListener('astro:page-load', updateBadgesUI);
</script>
