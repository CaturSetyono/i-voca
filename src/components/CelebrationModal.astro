---
---

<div id="celebration-modal" class="fixed inset-0 z-50 flex items-center justify-center p-6 hidden">
	<!-- Backdrop -->
	<div class="absolute inset-0 bg-brand-secondary/40 backdrop-blur-md"></div>
	
	<!-- Modal Content -->
	<div class="relative w-full max-w-sm clay-card bg-white flex flex-col items-center text-center gap-6 animate-zoom-in">
		<div id="modal-icon-container" class="h-32 w-32 flex items-center justify-center rounded-3xl border-2 border-brand-outline bg-brand-bg shadow-inner relative overflow-hidden">
			<img id="modal-badge-icon" src="" alt="Badge" class="w-20 h-20 hidden" />
			<div id="modal-level-icon" class="text-6xl font-black text-brand-primary font-display hidden">1</div>
		</div>

		<div class="flex flex-col gap-2">
			<h2 id="modal-title" class="text-3xl font-black uppercase tracking-tighter leading-none text-brand-secondary font-display">SELAMAT!</h2>
			<p id="modal-message" class="font-bold text-brand-primary uppercase text-[10px] tracking-[0.2em]">Kamu naik level!</p>
		</div>

		<div id="modal-badge-info" class="hidden flex flex-col gap-1">
			<h3 id="modal-badge-name" class="font-black text-xl leading-tight text-brand-secondary">Novice Smith</h3>
			<p id="modal-badge-desc" class="text-xs font-medium italic text-gray-400 px-4">Menandakan pengguna mulai menempa fondasi bahasanya.</p>
		</div>

		<button id="close-modal" class="clay-btn w-full py-4 text-xl">
			Mantap!
		</button>
	</div>
</div>

<script>
	import { popPendingCelebrations } from '../utils/storage.js';

	const badges = {
		badge_01: { name: 'Novice Smith', desc: 'Menandakan Anda telah menempa fondasi bahasa Anda.', icon: '/assets/badges/badge_01.svg' },
		badge_02: { name: 'Word Weaver', desc: 'Anda mulai mahir merajut untaian kata-kata dasar.', icon: '/assets/badges/badge_02.svg' },
		badge_03: { name: 'Fluent Voyager', desc: 'Siap berlayar lebih jauh ke samudera percakapan.', icon: '/assets/badges/badge_03.svg' },
		badge_04: { name: 'Vocab Titan', desc: 'Kekuatan memori kosakata Anda sungguh luar biasa.', icon: '/assets/badges/badge_04.svg' }
	};

	let celebrationQueue: any[] = [];
	let isModalOpen = false;

	function initModal() {
		const modal = document.getElementById('celebration-modal');
		const modalTitle = document.getElementById('modal-title');
		const modalMessage = document.getElementById('modal-message');
		const modalBadgeInfo = document.getElementById('modal-badge-info');
		const modalBadgeName = document.getElementById('modal-badge-name');
		const modalBadgeDesc = document.getElementById('modal-badge-desc');
		const modalBadgeIcon = document.getElementById('modal-badge-icon') as HTMLImageElement;
		const modalLevelIcon = document.getElementById('modal-level-icon');
		const closeModal = document.getElementById('close-modal');

		if (!modal) return;

		function showModal() {
			modal?.classList.remove('hidden');
			isModalOpen = true;
		}

		function hideModal() {
			modal?.classList.add('hidden');
			isModalOpen = false;
		}

		function processQueue() {
			if (isModalOpen || celebrationQueue.length === 0) return;

			const celebration = celebrationQueue.shift();
			const { type, data } = celebration;

			if (type === 'level-up') {
				const level = data.level;
				if (modalTitle) modalTitle.textContent = 'NAIK LEVEL!';
				if (modalMessage) modalMessage.textContent = `Kamu sekarang level ${level}`;
				if (modalLevelIcon) {
					modalLevelIcon.textContent = level.toString();
					modalLevelIcon.classList.remove('hidden');
				}
				modalBadgeIcon?.classList.add('hidden');
				modalBadgeInfo?.classList.add('hidden');
			} else if (type === 'badge-unlocked') {
				const badgeId = data.badgeId;
				const badge = (badges as any)[badgeId];
				
				if (badge) {
					if (modalTitle) modalTitle.textContent = 'BADGE BARU!';
					if (modalMessage) modalMessage.textContent = 'Kamu membuka pencapaian baru';
					if (modalBadgeName) modalBadgeName.textContent = badge.name;
					if (modalBadgeDesc) modalBadgeDesc.textContent = badge.desc;
					if (modalBadgeIcon) {
						modalBadgeIcon.src = badge.icon;
						modalBadgeIcon.classList.remove('hidden');
					}
					modalLevelIcon?.classList.add('hidden');
					modalBadgeInfo?.classList.remove('hidden');
				}
			}

			showModal();
		}

		closeModal?.addEventListener('click', () => {
			hideModal();
			setTimeout(processQueue, 300);
		});

		window.addEventListener('level-up', (e: any) => {
			celebrationQueue.push({ type: 'level-up', data: e.detail });
			processQueue();
		});

		window.addEventListener('badge-unlocked', (e: any) => {
			celebrationQueue.push({ type: 'badge-unlocked', data: e.detail });
			processQueue();
		});

		// Check pending on load
		setTimeout(() => {
			const pending = popPendingCelebrations();
			if (pending.length > 0) {
				celebrationQueue.push(...pending);
				processQueue();
			}
		}, 800);
	}

	document.addEventListener('astro:page-load', initModal);
</script>

